@article{kontogiannis2026cough,
  author       = {Kontogiannis, Georgios and Tzamalis, Pantelis and Nikoletseas, Sotiris and Karamanidou, Theoni and Stavropoulos, Thanos G.},
  title        = {On-device Cough Detection and Respiratory Disease Classification Enhanced by Generative Data Augmentation},
  journal      = {Computers in Biology and Medicine},
  year         = {2026},
  note         = {In Press},
  bibtex_show  = {true},
  selected     = {true},
  abbr         = {CBM},
  abstract     = {We present an end-to-end on-device pipeline for cough detection and respiratory disease classification (asthma vs. COPD) from tracheal-acquired smartphone recordings. A deep generative model synthesizes clinically realistic cough and lung sounds to address training data scarcity, improving classifier robustness across recording conditions. The resulting models are quantized and deployed for real-time inference on commodity Android hardware.},
}

@article{kalogeropoulos2025spectral,
  author       = {Kalogeropoulos, Nikolaos-Rafail and Kontogiannis, Georgios and Makris, Christos},
  title        = {Spectral clustering and query expansion using embeddings on the graph-based extension of the set-based information retrieval model},
  journal      = {Expert Systems with Applications},
  volume       = {263},
  pages        = {125771},
  year         = {2025},
  bibtex_show  = {true},
  abbr         = {ESWA},
  abstract     = {We extend the set-based information retrieval model to a graph-based formulation and improve retrieval quality through spectral clustering and embedding-driven query expansion. Experiments on standard benchmarks demonstrate consistent gains in precision and recall over baseline graph retrieval methods.},
}

@article{kapetanidis2024respiratory,
  author       = {Kapetanidis, Panagiotis and Kalioras, Fotios and Tsakonas, Christos and Tzamalis, Pantelis and Kontogiannis, Georgios and Karamanidou, Theoni and Stavropoulos, Thanos G. and Nikoletseas, Sotiris},
  title        = {Respiratory diseases diagnosis using audio analysis and artificial intelligence: a systematic review},
  journal      = {Sensors},
  volume       = {24},
  number       = {4},
  pages        = {1173},
  year         = {2024},
  bibtex_show  = {true},
  abbr         = {Sensors},
  abstract     = {This systematic review surveys the landscape of AI-driven respiratory disease diagnosis from audio signals, covering datasets, feature extraction approaches, deep learning architectures, and deployment considerations. We synthesize findings across 100+ studies to identify open challenges in data heterogeneity, model robustness, and clinical translation.},
}

@inproceedings{kontogiannis2026eusipco,
  author       = {Kontogiannis, Georgios and Tzamalis, Pantelis and Nikoletseas, Sotiris},
  title        = {Metadata-Conditioned Audio Transformers for Adaptive Respiratory Sound Classification},
  booktitle    = {Proceedings of the 34th European Signal Processing Conference (EUSIPCO)},
  year         = {2026},
  note         = {In Press, Acceptance Rate: 50\%},
  bibtex_show  = {true},
  selected     = {true},
  abbr         = {EUSIPCO},
  abstract     = {We propose a metadata-conditioned transformer architecture for respiratory sound classification that adapts its representations at inference time using patient-level clinical metadata (age, sex, BMI, recording device). Conditioning on metadata at the attention layer significantly improves classification of underrepresented patient subgroups without requiring separate models per subgroup.},
}

@inproceedings{kontogiannis2024dcoss,
  author       = {Kontogiannis, Georgios and Tzamalis, Pantelis and Nikoletseas, Sotiris},
  title        = {Exploring the Impact of Synthetic Data on Human Gesture Recognition Tasks Using {GANs}},
  booktitle    = {Proceedings of the 2024 20th International Conference on Distributed Computing in Smart Systems and the Internet of Things (DCOSS-IoT)},
  pages        = {384--391},
  publisher    = {IEEE},
  year         = {2024},
  bibtex_show  = {true},
  abbr         = {DCOSS},
  abstract     = {We investigate the utility of GAN-generated synthetic IMU data for human gesture recognition. Through controlled experiments varying the proportion of real vs. synthetic samples, we characterize when synthetic augmentation helps, hurts, or is neutral, providing practical guidelines for practitioners working with small IoT sensor datasets.},
}

@article{kontogiannis2026jaundice,
  author       = {Kontogiannis, Georgios and Tzamalis, Pantelis and Velissaris, Dimitris and Nikoletseas, Sotiris},
  title        = {{AI}-Based Jaundice Assessment from Ocular Images: A Structured Survey of Methods, Datasets, and Open Challenges},
  journal      = {Healthcare Informatics Research},
  year         = {2026},
  note         = {Under Review},
  bibtex_show  = {true},
  abbr         = {HIR},
  abstract     = {We survey methods, datasets, and open challenges for non-invasive jaundice assessment from smartphone-captured ocular images. The review covers scleral segmentation pipelines, colorimetric analysis, and multi-modal approaches that integrate imaging with hematological biomarkers, identifying key gaps for clinical deployment.},
}

@article{kontogiannis2026stethoscope,
  author       = {Kontogiannis, Georgios and Tzamalis, Pantelis and Nikoletseas, Sotiris and Karamanidou, Theoni and Stavropoulos, Thanos G.},
  title        = {Transforming Smartphones into Stethoscopes: Edge {AI} for Asthma and {COPD}},
  journal      = {IEEE Journal of Biomedical and Health Informatics},
  year         = {2026},
  note         = {Under Review},
  bibtex_show  = {true},
  abbr         = {JBHI},
  abstract     = {We present a complete smartphone-based pipeline for distinguishing asthma from COPD using acoustic biomarkers extracted from tracheal lung sounds. The system integrates domain-adaptive feature extraction with an edge-optimized classifier, enabling real-time differential diagnosis without specialized hardware or clinical-grade microphones.},
}
